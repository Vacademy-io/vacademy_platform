#!/usr/bin/env sh
# Vacademy design-system commit gate.
# Blocks commits that introduce UI drift (raw hex, arbitrary Tailwind values,
# inline styles, banned icon libraries) in either frontend. Only staged,
# changed UI files are checked — existing/legacy code is never touched.
# Source of truth: frontend-admin-dashboard/docs/design-system/
#
# Activation (one-time, per clone): git config core.hooksPath .husky
# (git stores hook paths locally, so each teammate runs this once.)

# Skip during merges / rebases / cherry-picks / reverts. These commits bring
# in pre-existing code from other branches that the gate isn't designed to
# police — re-checking thousands of unrelated files would always block.
if [ -e "$(git rev-parse --git-dir)/MERGE_HEAD" ] \
   || [ -e "$(git rev-parse --git-dir)/CHERRY_PICK_HEAD" ] \
   || [ -e "$(git rev-parse --git-dir)/REVERT_HEAD" ] \
   || [ -d "$(git rev-parse --git-dir)/rebase-merge" ] \
   || [ -d "$(git rev-parse --git-dir)/rebase-apply" ]; then
  exit 0
fi

files=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '^frontend-(admin-dashboard|learner-dashboard-app)/src/.*\.(tsx|ts|css)$' || true)

if [ -z "$files" ]; then
  exit 0
fi

# Catalogue style engine / CSS byte-sync gate. The admin canvas and the
# learner renderer each carry a copy of the shared style engine + catalogue
# CSS; a drifted copy silently breaks canvas parity. Near-free (5 byte
# compares); fix with: node scripts/check-style-engine-sync.mjs --fix
node scripts/check-style-engine-sync.mjs
sync_status=$?
if [ "$sync_status" -ne 0 ]; then
  echo ""
  echo "Commit blocked: synced catalogue style files drifted between the apps."
  echo "Run: node scripts/check-style-engine-sync.mjs --fix  then re-stage."
  exit $sync_status
fi

# shellcheck disable=SC2086
node scripts/design-lint.mjs $files
status=$?

if [ "$status" -ne 0 ]; then
  echo ""
  echo "Commit blocked by the Vacademy design system. Fix the violations above"
  echo "(see frontend-admin-dashboard/docs/design-system/), then re-stage and commit."
  echo "To bypass in a genuine emergency: git commit --no-verify"
fi

exit $status
