# Copy to .env and fill in. Used by join_storm.py (and mirrors the env the
# bbb-stress-test pods expect). Point at the ISOLATED TEST CLONE, never prod.

# Base URL ending in /bigbluebutton  (join_storm.py appends /api/...).
# bbb-stress-test conventionally wants the trailing slash form.
BBB_URL=https://meet-test.vacademy.io/bigbluebutton/

# Shared secret of the TEST clone (bbb-conf --secret on that box).
BBB_SECRET=replace-with-test-clone-secret

# Meeting the pods join. Create it with:  python3 join_storm.py create
BBB_MEETING_ID=loadtest-001

# Per-pod client mix for the Puppeteer pods (total = these x Job.parallelism).
# Incident profile across 10 pods => 160 listen-only + 40 webcam = 200 users, 40 cams.
BBB_CLIENTS_LISTEN_ONLY=16
BBB_CLIENTS_MIC=0
BBB_CLIENTS_WEBCAM=4
BBB_TEST_DURATION=900
