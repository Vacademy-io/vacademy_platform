    "steps": [
      { "screen": "directory", "target": null, "title": "Every learner, one directory", "text": "Search 2,000+ learners with type-ahead, filter by batch, status, payment, session-expiry window or any custom field, and export any view to CSV — including a credentials export for offline distribution." },
      { "screen": "directory", "target": "dir-stats", "title": "Registrar problems surface themselves", "text": "Live headcounts flag what needs action today: pending approvals to accept or decline, enrollments expiring within 30 days, and overdue payments — before parents call to complain." },
      { "screen": "directory", "target": "dir-table", "title": "Act on any row, or any selection", "text": "Open a side-panel profile — guardian info, batch memberships, per-chapter progress — or multi-select to change batch, extend access, re-register for the next session, or blast WhatsApp and email." },
      { "screen": "bulk-ops", "target": "bulk-form", "title": "Move thousands of learners at once", "text": "Bulk-assign a CSV of new users, an explicit list, or a saved filter into one or more batches — with access days, offline payment capture (amount, mode, transaction ID) and optional credential delivery." },
      { "screen": "bulk-ops", "target": "bulk-preview", "title": "Dry-run before you commit", "text": "A simulation shows the per-learner outcome first: who gets enrolled, who's skipped by the duplicate rule, and which rows need fixes. Re-runs are always safe — nothing changes until you commit." },
      { "screen": "batches", "target": "seat-stats", "title": "Seat inventory, live", "text": "Cap seats per batch and watch capacity institute-wide. Seats reserve and release automatically during enrollment — no overselling — and nearly-full batches are flagged so you add capacity or push urgency." },
      { "screen": "batches", "target": "batch-cards", "title": "Sessions, levels and batches", "text": "A guided wizard creates course, level and academic session in sequence, producing a ready-to-enroll batch. Parent-child hierarchies and learner groups keep large cohorts organized." },
      { "screen": "batches", "target": "suborg-list", "title": "Branches and franchises under one roof", "text": "Each sub-org gets its own team, seat allocation and financial ledger — invoices, payments, waivers, penalties. Partners manage their own rosters through a self-serve screen, even by public self-registration link." },
      { "screen": "hr", "target": "hr-stats", "title": "A real HR suite, built in", "text": "Staff check in manually, by biometric device or geo-location; leave policies accrue monthly or yearly; and regularizations, leave and reimbursements route through multi-step approval chains." },
      { "screen": "hr", "target": "payroll-table", "title": "Payroll from calculation to paid", "text": "Monthly runs auto-calculate every entry from salary structures with regime-aware Indian tax. Hold or release individual payouts, generate payslips in bulk, and export bank-ready transfer files." }
    ]
