    "steps": [
      { "screen": "whitelabel", "target": null, "title": "Your platform, not ours", "text": "Everything a learner or parent touches runs on your domains under your brand — Vacademy stays invisible. This is the control room where Prakash Career Institute makes the platform its own." },
      { "screen": "whitelabel", "target": "wl-form", "title": "One-click domain, DNS and SSL", "text": "Point learn.prakashinstitute.in at your learner portal and the wizard provisions DNS and SSL automatically. Each domain carries its own logo, theme color, fonts, tab title and legal links." },
      { "screen": "whitelabel", "target": "wl-portals", "title": "Separate domains per portal", "text": "Run distinct domains for learner and admin portals, and give each branch or partner brand its own sub-org entry point. Attach your Play Store and App Store links so every portal promotes your apps." },
      { "screen": "naming", "target": "nm-table", "title": "The platform speaks your language", "text": "Rename 16+ terms — Course, Batch, Learner, Session, Module and more — per institute. Call a Course a Program and a Batch a Cohort; the change flows through menus, dialogs, reports and your white-label domains." },
      { "screen": "naming", "target": "nm-edit", "title": "Real plurals, not just an 's'", "text": "Every term has independent singular and plural forms — 'Faculty/Faculty', 'Child/Children' — plus a plain-language explanation of what it controls, so you rename with confidence." },
      { "screen": "brandedapp", "target": "app-head", "title": "Your own app in the stores", "text": "The learner app ships as a branded Android and iOS build under your institute's name, icon and store listing — published on your developer account. Windows and Mac desktop apps too." },
      { "screen": "brandedapp", "target": "app-update", "title": "Instant updates, protected content", "text": "Over-the-air releases push fixes straight to devices — no app-store wait, with one-click rollback. Push notifications go out under your app identity, and privacy screens block screenshots of paid content." },
      { "screen": "security", "target": "sec-roles", "title": "Roles across every branch", "text": "Staff carry roles like Admin, Faculty, Evaluator and Course Creator — renamed to your terms. One person can work across the main campus and the Kota branch, switching workspaces without re-login." },
      { "screen": "security", "target": "sec-login", "title": "Sign-in rules you control", "text": "Per portal, switch on password, email OTP, WhatsApp OTP, Google or GitHub sign-in — and keep access invite-only. A 2-device limit stops account sharing; students log out an old device themselves." }
    ]
  }
