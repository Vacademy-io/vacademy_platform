# Do not set NODE_ENV variable, it is auto managed
# https://nextjs.org/docs/messages/non-standard-node-env

# --- Sentry --------------------------------------------------------------
# Both must be set together for client-side error reporting to work.
# Without VITE_ENABLE_SENTRY=true, Sentry.init() is skipped in src/index.tsx
# and captureException calls become no-ops everywhere (including the
# reportApiError helper used across the assessment/homework flows).
#
# Dev   : leave unset to keep local consoles quiet.
# Stage : VITE_ENABLE_SENTRY=true with the staging DSN.
# Prod  : VITE_ENABLE_SENTRY=true with the production DSN.
#         Mirror these in Cloudflare Pages → Settings → Environment variables.
VITE_ENABLE_SENTRY=false
VITE_SENTRY_DSN=