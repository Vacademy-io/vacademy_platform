# =============================================================================
# topology.env — single source of truth for the Hetzner Singapore migration
# =============================================================================
#
# This file is sourced by EVERY bring-up / setup / cutover script in this
# directory (bring-up-k3s.sh, bring-up-postgres.sh,
# setup-streaming-replication.sh, setup-pgbackrest.sh, dump-restore.sh).
#
# Deploy procedure:
#   1. Copy this file to /root/vacademy-migration/topology.env on EACH box
#      (k3s-node-1/2/3, db-primary, db-standby) before running any script.
#      Most scripts also accept it as a sibling of the script itself; the
#      `TOPOLOGY_FILE=/path/to/topology.env` env var overrides the default.
#   2. Replace every REPLACE_* token below with the real value from the
#      Hetzner Storage Box admin UI. Do NOT commit a filled-in copy to git.
#   3. `chmod 600 /root/vacademy-migration/topology.env` — it contains
#      Storage Box credentials.
#
# Values below match docs/TOPOLOGY.md. If you edit IPs here, edit them there
# too — both files are checked at runtime.
# =============================================================================

# -----------------------------------------------------------------------------
# k3s nodes (CCX23 — 4 vCPU AMD ded / 16 GB / 160 GB NVMe each)
# -----------------------------------------------------------------------------
K3S_NODE_1_PUBLIC="5.223.88.202"
K3S_NODE_1_PRIVATE="10.0.0.11"

K3S_NODE_2_PUBLIC="5.223.54.6"
K3S_NODE_2_PRIVATE="10.0.0.12"

K3S_NODE_3_PUBLIC="5.223.55.238"
K3S_NODE_3_PRIVATE="10.0.0.13"

# -----------------------------------------------------------------------------
# Postgres boxes
#   db-primary : CCX13 (2 vCPU AMD ded / 8 GB / 80 GB NVMe)
#   db-standby : CPX22 (3 vCPU Intel shared / 4 GB / 80 GB NVMe)
# -----------------------------------------------------------------------------
DB_PRIMARY_PUBLIC="5.223.55.54"
DB_PRIMARY_PRIVATE="10.0.0.21"

DB_STANDBY_PUBLIC="5.223.53.24"
DB_STANDBY_PRIVATE="10.0.0.22"

# dump-restore.sh uses HETZNER_DB_PRIMARY_IP as the SSH target from the
# operator's laptop / Linode prod box. Public IP is correct here (we SSH in
# over the internet, not the private network).
HETZNER_DB_PRIMARY_IP="${DB_PRIMARY_PUBLIC}"
HETZNER_SSH_USER="root"

# -----------------------------------------------------------------------------
# Hetzner Storage Box (pgBackRest sftp repo, BX11 plan)
# -----------------------------------------------------------------------------
# From the Hetzner Storage Box admin UI. Host is usually of the form
# `u123456.your-storagebox.de`; user is `u123456`.
STORAGE_BOX_HOST="REPLACE_STORAGE_BOX_HOST"
STORAGE_BOX_USER="REPLACE_STORAGE_BOX_USER"

# pgBackRest uses SSH KEY auth, so STORAGE_BOX_PASS is optional. Leave it
# unset unless you specifically need the password elsewhere. Never commit it.
STORAGE_BOX_PASS="REPLACE_STORAGE_BOX_PASS_OR_LEAVE_EMPTY"
