# Public base URL of THIS service INCLUDING the /voice-bot-service ingress prefix —
# goes into the <Stream> wss URL. For a local ngrok test:
#   PUBLIC_BASE=https://<ngrok-host>/voice-bot-service
PUBLIC_BASE=https://backend-stage.vacademy.io/voice-bot-service

# admin_core (control plane)
ADMIN_CORE_BASE=https://backend-stage.vacademy.io
# Internal identity: register this row in admin_core's client_secret_key table.
VOICE_BOT_CLIENT_NAME=voice_bot_service
VOICE_BOT_CLIENT_SECRET=

# Sarvam (STT + LLM + TTS — the default end-to-end stack)
SARVAM_API_KEY=
# SARVAM_STT_MODEL=saaras:v3
# SARVAM_LLM_MODEL=sarvam-105b
# SARVAM_TTS_MODEL=bulbul:v3
# SARVAM_TTS_VOICE=priya

# Conversation + analysis LLM (drives BOTH; default sarvam = India-hosted
# sarvam-105b with reasoning_effort=null — 0.14s TTFT from Mumbai, ~5x faster
# than Gemini. The null is hard-coded in providers.py/report.py; never remove
# it: with thinking on these models take 6-14s or return content=None).
# LLM_PROVIDER=sarvam
# Fallbacks: LLM_PROVIDER=google (direct Gemini) | openrouter (proxy)
GEMINI_API_KEY=
# GOOGLE_LLM_MODEL=gemini-3.1-flash-lite
# GOOGLE_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-3.1-flash-lite

# Turn-taking latency (seconds). vad_stop: silence that ends the caller's turn;
# agg_timeout: extra wait for a late final transcript. Pipecat defaults 0.8/0.5.
# VAD_STOP_SECS=0.5
# AGG_TIMEOUT_SECS=0.2

# Bulbul speaking pace (1.0 = native; founder found 0.95 too slow on the phone).
# TTS_PACE=1.1

# Instant filler acknowledgment while the LLM composes ("Hmm…") — cuts perceived
# dead air from ~2.2s to ~1s. Probability 0 disables; phrases are comma-separated.
# FILLER_PROBABILITY=0.7
# FILLER_PHRASES=Hmm…,Achha…,Ji…

# NOTE: no Plivo credentials here on purpose — the serializer runs with
# auto_hang_up=False (the call must survive the stream's end so the <Redirect>
# to /plivo/ai-next can serve the human-handoff <Dial> or the hangup).
