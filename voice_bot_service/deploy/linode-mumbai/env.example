# Copy to /opt/voice-bot/.env on the Mumbai box and fill the blanks.
# Values mirror the k8s deployment in Singapore — same identity, same vendors.

# Public base of THIS box (must match the Caddyfile hostname + DNS record).
PUBLIC_BASE=https://voice-bot-in.vacademy.io/voice-bot-service

# Control plane stays in Singapore — 3 small HTTP calls per call, not latency-critical.
ADMIN_CORE_BASE=https://backend-stage.vacademy.io

# Internal identity: must match a row in admin_core's client_secret_key table.
# (Prod currently reuses the admin_core_service row — same values as the k8s env.)
VOICE_BOT_CLIENT_NAME=admin_core_service
VOICE_BOT_CLIENT_SECRET=

# Sarvam STT (saaras) + TTS (bulbul)
SARVAM_API_KEY=

# Conversation + analysis LLM — Gemini hit directly (Mumbai edge).
LLM_PROVIDER=google
GEMINI_API_KEY=

# Voice tuning (same as prod)
TTS_PACE=1.1
# VAD_STOP_SECS=0.5
# AGG_TIMEOUT_SECS=0.2

# CI rewrites this line on every deploy with the immutable :<git-sha> tag.
VOICE_BOT_IMAGE=public.ecr.aws/e0x1f4p4/voice-bot-service/voice-bot-service-repo:latest
